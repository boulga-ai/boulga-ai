# LLM
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your_jwt_secret_here_min_32_chars
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here_min_32_chars

# Resend (email)
RESEND_API_KEY=re_your_resend_api_key_here

# CinetPay (mobile money)
CINETPAY_API_KEY=your_cinetpay_api_key_here
CINETPAY_SITE_ID=your_cinetpay_site_id_here
CINETPAY_SECRET=your_cinetpay_secret_here

# WhatsApp Business API
WHATSAPP_TOKEN=your_whatsapp_token_here
WHATSAPP_PHONE_ID=your_whatsapp_phone_id_here
WHATSAPP_VERIFY_TOKEN=your_whatsapp_verify_token_here
META_APP_SECRET=your_meta_app_secret_here

# Cron (endpoint interne Railway)
CRON_SECRET=your_cron_secret_here

# Application
CORS_ORIGINS=https://your-frontend.vercel.app,http://localhost:3000
FRONTEND_URL=https://your-frontend.vercel.app
BACKEND_URL=https://your-backend.railway.app
APP_ENV=production
